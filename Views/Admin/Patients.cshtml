@model IEnumerable<HospitalManagementPortal.Models.PatientProfile>
@{
    ViewData["Title"] = "Manage Patients";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="font-heading fw-bold mb-1">Patient Registry</h2>
            <p class="text-secondary mb-0">Browse and inspect patient records and medical histories.</p>
        </div>
        <a asp-action="AddPatient" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="bi bi-person-plus-fill"></i> Add Patient
        </a>
    </div>

    <div class="card glass-card border-0 p-4 shadow-sm">
        @if (Model != null && Model.Any())
        {
            <div class="mb-3">
                <input type="text" id="patientSearchInput" class="form-control form-control-custom w-100" placeholder="🔍 Search patients by name or email..." onkeyup="searchPatientsTable()" />
            </div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-people fs-1 text-muted"></i>
                <p class="text-secondary small mt-2">No patients have registered in the portal yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table custom-table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Patient Name</th>
                            <th>Date of Birth</th>
                            <th>Gender</th>
                            <th>Blood Group</th>
                            <th>Medical History Summary</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var patient in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border" style="width: 45px; height: 45px;">
                                            <i class="bi bi-person fs-4 text-secondary"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@patient.User.FullName</div>
                                            <div class="text-muted small">@patient.User.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@patient.DateOfBirth.ToString("dd MMM yyyy")</td>
                                <td>@patient.Gender</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(patient.BloodGroup))
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-circle px-2 py-1">@patient.BloodGroup</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    <span class="text-muted small"><i class="bi bi-lock-fill text-danger me-1"></i>Protected Health Info</span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="EditPatient" asp-route-id="@patient.Id" class="btn btn-sm btn-outline-primary" title="Edit Patient">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="DeletePatient" asp-route-id="@patient.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this patient? This will permanently delete the patient user and profile.');" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Patient">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function searchPatientsTable() {
            const input = document.getElementById('patientSearchInput').value.toLowerCase();
            const rows = document.querySelectorAll('tbody tr');
            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                if (text.includes(input)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
    </script>
}
