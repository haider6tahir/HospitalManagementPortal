@model IEnumerable<HospitalManagementPortal.Models.DoctorProfile>
@{
    ViewData["Title"] = "Manage Doctors";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="font-heading fw-bold mb-1">Doctor Management Panel</h2>
            <p class="text-secondary mb-0">Browse and inspect all registered medical practitioners.</p>
        </div>
        <a asp-action="AddDoctor" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="bi bi-person-plus-fill"></i> Add Doctor
        </a>
    </div>

    <div class="card glass-card border-0 p-4 shadow-sm">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-people fs-1 text-muted"></i>
                <p class="text-secondary small mt-2">No doctors have registered in the portal yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table custom-table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Doctor Details</th>
                            <th>Specialization</th>
                            <th>Credentials</th>
                            <th>Experience</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in Model)
                        {
                            string statusBadgeClass = doc.Status switch
                            {
                                "Approved" => "bg-success",
                                "Rejected" => "bg-danger",
                                _ => "bg-warning text-dark"
                            };
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrEmpty(doc.ProfilePicturePath))
                                        {
                                            <img src="@doc.ProfilePicturePath" alt="Dr. @doc.User.FullName" class="rounded-circle border" style="width: 45px; height: 45px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border" style="width: 45px; height: 45px;">
                                                <i class="bi bi-person-heart fs-4 text-primary"></i>
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-semibold">@doc.User.FullName</div>
                                            <div class="text-muted small">@doc.User.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-teal-100 text-teal-800" style="background: rgba(13, 148, 136, 0.1); color: var(--primary-color);">@doc.Specialization</span>
                                </td>
                                <td>
                                    <div class="fw-medium">@doc.Qualifications</div>
                                    <div class="text-muted small text-truncate" style="max-width: 250px;" title="@doc.Biography">@doc.Biography</div>
                                </td>
                                <td>@doc.ExperienceYears years</td>
                                <td>
                                    <span class="badge @statusBadgeClass rounded-pill px-3 py-1.5 small">@doc.Status</span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="EditDoctor" asp-route-id="@doc.Id" class="btn btn-sm btn-outline-primary" title="Edit Doctor">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="DeleteDoctor" asp-route-id="@doc.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this doctor? This will permanently delete the doctor user and profile.');" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Doctor">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
