@model IEnumerable<HospitalManagementPortal.Models.Appointment>
@{
    ViewData["Title"] = "Appointments Audit";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="font-heading fw-bold mb-1">Appointments Log</h2>
            <p class="text-secondary mb-0">Audit and inspect all booking histories across the portal.</p>
        </div>
    </div>

    <div class="card glass-card border-0 p-4 shadow-sm">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-calendar3 fs-1 text-muted"></i>
                <p class="text-secondary small mt-2">No appointments have been requested yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table custom-table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Patient Name</th>
                            <th>Assigned Doctor</th>
                            <th>Appointment Slot</th>
                            <th>Symptoms Description</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model)
                        {
                            string statusBadgeClass = app.Status switch
                            {
                                "Approved" => "bg-success",
                                "Rejected" => "bg-danger",
                                _ => "bg-warning text-dark"
                            };
                            <tr>
                                <td>
                                    <div class="fw-semibold">@app.Patient.User.FullName</div>
                                    <div class="text-muted small">@app.Patient.User.Email</div>
                                </td>
                                <td>
                                    <div class="fw-semibold">@app.Doctor.User.FullName</div>
                                    <div class="badge bg-teal-100 text-teal-800" style="background: rgba(13, 148, 136, 0.1); color: var(--primary-color);">@app.Doctor.Specialization</div>
                                </td>
                                <td>
                                    <div class="fw-medium">@app.AppointmentDate.ToString("dd MMM yyyy")</div>
                                    <div class="text-muted small">@app.AppointmentDate.ToString("hh:mm tt")</div>
                                </td>
                                <td>
                                    <span class="text-muted small"><i class="bi bi-lock-fill text-danger me-1"></i>Protected Health Info</span>
                                </td>
                                <td>
                                    <span class="badge @statusBadgeClass rounded-pill px-3 py-1.5 small">@app.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
