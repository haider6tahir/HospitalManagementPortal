@{
    ViewData["Title"] = "Doctor Dashboard";
    var todayAppointments = ViewBag.TodayAppointments as List<HospitalManagementPortal.Models.Appointment>;
    var upcomingAppointments = ViewBag.UpcomingAppointments as List<HospitalManagementPortal.Models.Appointment>;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="font-heading fw-bold mb-1">Welcome, Dr. @ViewBag.DoctorName</h2>
            <p class="text-secondary mb-0">Overview of your consultations, patients, and schedule today.</p>
        </div>
        <div>
            <a asp-action="Availability" class="btn btn-gradient-secondary rounded-pill px-4">
                <i class="bi bi-clock me-2"></i>Manage Hours
            </a>
        </div>
    </div>

    <!-- Stats row -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="stat-card bg-gradient-primary">
                <div class="stat-icon"><i class="bi bi-calendar2-check"></i></div>
                <div class="stat-num">@ViewBag.TodayAppointmentsCount</div>
                <div class="stat-label">Appointments Today</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card bg-gradient-accent">
                <div class="stat-icon"><i class="bi bi-calendar-event"></i></div>
                <div class="stat-num">@ViewBag.UpcomingAppointmentsCount</div>
                <div class="stat-label">Upcoming Agenda</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card bg-gradient-primary" style="filter: hue-rotate(90deg);">
                <div class="stat-icon"><i class="bi bi-journal-check"></i></div>
                <div class="stat-num">@ViewBag.ConsultationsCompleted</div>
                <div class="stat-label">Consultations Done</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Today's Appointments -->
        <div class="col-lg-7">
            <div class="card glass-card border-0 p-4 shadow-sm h-100">
                <h5 class="font-heading fw-bold mb-3"><i class="bi bi-play-circle text-primary me-2"></i>Today's Appointments Queue</h5>
                
                @if (todayAppointments == null || !todayAppointments.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-minus fs-1 text-muted"></i>
                        <p class="text-secondary small mt-2">No appointments scheduled for today.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table custom-table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Patient Details</th>
                                    <th>Time</th>
                                    <th>Symptoms</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in todayAppointments)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@app.Patient.User.FullName</div>
                                            <div class="text-muted small">DOB: @app.Patient.DateOfBirth.ToString("dd MMM yyyy") (@app.Patient.Gender)</div>
                                        </td>
                                        <td class="fw-medium text-secondary">
                                            @app.AppointmentDate.ToString("hh:mm tt")
                                        </td>
                                        <td class="small text-muted">@app.SymptomDescription</td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-gradient btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#consultNotesModal-@app.Id">
                                                Consult
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Upcoming Appointments -->
        <div class="col-lg-5">
            <div class="card glass-card border-0 p-4 shadow-sm h-100">
                <h5 class="font-heading fw-bold mb-3"><i class="bi bi-calendar-event text-secondary me-2"></i>Upcoming Agenda</h5>
                
                @if (upcomingAppointments == null || !upcomingAppointments.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-x fs-1 text-muted"></i>
                        <p class="text-secondary small mt-2">No upcoming appointments scheduled.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var app in upcomingAppointments)
                        {
                            <div class="list-group-item bg-transparent px-0 py-3 border-bottom">
                                <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                                    <h6 class="mb-0 fw-semibold">@app.Patient.User.FullName</h6>
                                    <small class="badge bg-teal-100 text-teal-800" style="background: rgba(13, 148, 136, 0.1); color: var(--primary-color);">@app.AppointmentDate.ToString("dd MMM, hh:mm tt")</small>
                                </div>
                                <p class="mb-0 text-muted small text-truncate">@app.SymptomDescription</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (todayAppointments != null && todayAppointments.Any())
{
    @foreach (var app in todayAppointments)
    {
        <!-- Notes Modal -->
        <div class="modal fade" id="consultNotesModal-@app.Id" tabindex="-1" aria-labelledby="modalLabel-@app.Id" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
                    <div class="modal-header border-0 bg-light p-4" style="border-top-left-radius: 16px; border-top-right-radius: 16px;">
                        <h5 class="modal-title font-heading fw-bold" id="modalLabel-@app.Id">Patient Consultation</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form asp-action="AddConsultationNotes" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="appointmentId" value="@app.Id" />
                        <div class="modal-body p-4 text-start">
                            <div class="mb-3">
                                <div class="small text-secondary fw-semibold">PATIENT</div>
                                <div class="fw-bold fs-5">@app.Patient.User.FullName</div>
                            </div>
                            <div class="mb-3 bg-light p-3 rounded-3 border">
                                <div class="small text-secondary fw-semibold">SYMPTOMS REPORTED</div>
                                <div class="small text-dark mt-1">@app.SymptomDescription</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small text-secondary fw-semibold">CONSULTATION NOTES & PRESCRIPTION</label>
                                <textarea name="notes" rows="5" class="form-control form-control-custom" placeholder="Write diagnosed symptoms, advice, and prescriptions here..." required>@app.ConsultationNotes</textarea>
                            </div>
                        </div>
                        <div class="modal-footer border-0 p-4 bg-light" style="border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
                            <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-gradient rounded-pill px-4">Save Notes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}
