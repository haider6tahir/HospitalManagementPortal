@{
    ViewData["Title"] = "Doctor Dashboard";
    var todayAppointments = ViewBag.TodayAppointments as List<HospitalManagementPortal.Models.Appointment>;
    var upcomingAppointments = ViewBag.UpcomingAppointments as List<HospitalManagementPortal.Models.Appointment>;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="font-heading fw-bold mb-1">Welcome, Dr. @ViewBag.DoctorName</h2>
            <p class="text-secondary mb-0">Overview of your consultations, patients, and schedule today.</p>
        </div>
        <div>
            <a asp-action="Availability" class="btn btn-gradient-secondary rounded-pill px-4">
                <i class="bi bi-clock me-2"></i>Manage Hours
            </a>
        </div>
    </div>

    <!-- Stats row -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="stat-card bg-gradient-primary">
                <div class="stat-icon"><i class="bi bi-calendar2-check"></i></div>
                <div class="stat-num">@ViewBag.TodayAppointmentsCount</div>
                <div class="stat-label">Appointments Today</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card bg-gradient-accent">
                <div class="stat-icon"><i class="bi bi-calendar-event"></i></div>
                <div class="stat-num">@ViewBag.UpcomingAppointmentsCount</div>
                <div class="stat-label">Upcoming Agenda</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card bg-gradient-primary" style="filter: hue-rotate(90deg);">
                <div class="stat-icon"><i class="bi bi-journal-check"></i></div>
                <div class="stat-num">@ViewBag.ConsultationsCompleted</div>
                <div class="stat-label">Consultations Done</div>
            </div>
        </div>
    </div>

    <!-- Dashboard Tabs -->
    <ul class="nav nav-pills custom-tabs mb-4" id="doctorDashboardTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active rounded-pill px-4" id="agenda-tab" data-bs-toggle="tab" data-bs-target="#agenda-pane" type="button" role="tab" aria-controls="agenda-pane" aria-selected="true"><i class="bi bi-calendar3 me-2"></i>My Agenda</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill px-4 ms-2" id="analytics-tab" data-bs-toggle="tab" data-bs-target="#analytics-pane" type="button" role="tab" aria-controls="analytics-pane" aria-selected="false" onclick="loadDoctorAnalytics()"><i class="bi bi-graph-up me-2"></i>Analytics & Trends</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill px-4 ms-2" id="calendar-tab" data-bs-toggle="tab" data-bs-target="#calendar-pane" type="button" role="tab" aria-controls="calendar-pane" aria-selected="false" onclick="loadDoctorCalendar()"><i class="bi bi-calendar-week me-2"></i>Schedule Calendar</button>
        </li>
    </ul>

    <div class="tab-content" id="doctorDashboardTabsContent">
        <!-- Tab 1: Agenda -->
        <div class="tab-pane fade show active" id="agenda-pane" role="tabpanel" aria-labelledby="agenda-tab">
            <div class="row g-4">
        <!-- Today's Appointments -->
        <div class="col-lg-7">
            <div class="card glass-card border-0 p-4 shadow-sm h-100">
                <h5 class="font-heading fw-bold mb-3"><i class="bi bi-play-circle text-primary me-2"></i>Today's Appointments Queue</h5>
                
                @if (todayAppointments == null || !todayAppointments.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-minus fs-1 text-muted"></i>
                        <p class="text-secondary small mt-2">No appointments scheduled for today.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table custom-table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Patient Details</th>
                                    <th>Time</th>
                                    <th>Symptoms</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in todayAppointments)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@app.Patient.User.FullName</div>
                                            <div class="text-muted small">DOB: @app.Patient.DateOfBirth.ToString("dd MMM yyyy") (@app.Patient.Gender)</div>
                                        </td>
                                        <td class="fw-medium text-secondary">
                                            @app.AppointmentDate.ToString("hh:mm tt")
                                        </td>
                                        <td class="small text-muted">@app.SymptomDescription</td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-gradient btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#consultNotesModal-@app.Id">
                                                Consult
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Upcoming Appointments -->
        <div class="col-lg-5">
            <div class="card glass-card border-0 p-4 shadow-sm h-100">
                <h5 class="font-heading fw-bold mb-3"><i class="bi bi-calendar-event text-secondary me-2"></i>Upcoming Agenda</h5>
                
                @if (upcomingAppointments == null || !upcomingAppointments.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-x fs-1 text-muted"></i>
                        <p class="text-secondary small mt-2">No upcoming appointments scheduled.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var app in upcomingAppointments)
                        {
                            <div class="list-group-item bg-transparent px-0 py-3 border-bottom">
                                <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                                    <h6 class="mb-0 fw-semibold">@app.Patient.User.FullName</h6>
                                    <small class="badge bg-teal-100 text-teal-800" style="background: rgba(13, 148, 136, 0.1); color: var(--primary-color);">@app.AppointmentDate.ToString("dd MMM, hh:mm tt")</small>
                                </div>
                                <p class="mb-0 text-muted small text-truncate">@app.SymptomDescription</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
            </div> <!-- End of original row -->
        </div> <!-- End of Tab 1: Agenda -->

        <!-- Tab 2: Analytics -->
        <div class="tab-pane fade" id="analytics-pane" role="tabpanel" aria-labelledby="analytics-tab">
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="card glass-card border-0 p-4 shadow-sm">
                        <h5 class="font-heading fw-bold mb-3"><i class="bi bi-graph-up text-primary me-2"></i>7-Day Patient Volume Trend</h5>
                        <div style="height: 320px; position: relative;">
                            <canvas id="doctorTrendChart"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card glass-card border-0 p-4 shadow-sm">
                        <h5 class="font-heading fw-bold mb-3"><i class="bi bi-pie-chart text-accent me-2"></i>Appointment Status Distribution</h5>
                        <div style="height: 320px; position: relative;">
                            <canvas id="doctorStatusChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 3: Calendar -->
        <div class="tab-pane fade" id="calendar-pane" role="tabpanel" aria-labelledby="calendar-tab">
            <div class="card glass-card border-0 p-4 shadow-sm">
                <h5 class="font-heading fw-bold mb-3"><i class="bi bi-calendar-week text-primary me-2"></i>Interactive Schedule Calendar</h5>
                <div id="doctorCalendar" class="p-2 bg-white rounded-3 shadow-xs border"></div>
            </div>
        </div>
    </div> <!-- End of Tab Content -->
</div>

@if (todayAppointments != null && todayAppointments.Any())
{
    @foreach (var app in todayAppointments)
    {
        <!-- Notes Modal -->
        <div class="modal fade" id="consultNotesModal-@app.Id" tabindex="-1" data-patient-id="@app.PatientId" aria-labelledby="modalLabel-@app.Id" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
                    <div class="modal-header border-0 bg-light p-4" style="border-top-left-radius: 16px; border-top-right-radius: 16px;">
                        <h5 class="modal-title font-heading fw-bold" id="modalLabel-@app.Id">Patient Consultation</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form asp-action="AddConsultationNotes" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="appointmentId" value="@app.Id" />
                        <div class="modal-body p-4 text-start">
                            <div class="row g-4">
                                <!-- Left Column: Form -->
                                <div class="col-md-6 border-end">
                                    <div class="mb-3">
                                        <div class="small text-secondary fw-semibold">PATIENT</div>
                                        <div class="fw-bold fs-5 text-primary">@app.Patient.User.FullName</div>
                                    </div>
                                    <div class="mb-3 bg-light p-3 rounded-3 border">
                                        <div class="small text-secondary fw-semibold">SYMPTOMS REPORTED</div>
                                        <div class="small text-dark mt-1">@app.SymptomDescription</div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small text-secondary fw-semibold">CONSULTATION NOTES & DIAGNOSIS</label>
                                        <textarea id="notes-@app.Id" name="notes" rows="5" class="form-control form-control-custom notes-textarea" data-app-id="@app.Id" placeholder="Write diagnosed symptoms, advice, and prescriptions here..." required>@app.ConsultationNotes</textarea>
                                        <div id="suggestions-@app.Id" class="mt-2 small d-none d-flex flex-wrap gap-1 align-items-center">
                                            <span class="text-secondary me-1"><i class="bi bi-lightbulb-fill text-warning"></i> suggestions:</span>
                                            <!-- Pills loaded dynamically -->
                                        </div>
                                    </div>
                                </div>

                                <!-- Right Column: Medical History -->
                                <div class="col-md-6">
                                    <h6 class="font-heading fw-bold mb-3 text-secondary"><i class="bi bi-clock-history me-2"></i>Medical History & Reports</h6>
                                    <div id="historyFeed-@app.Id" style="max-height: 350px; overflow-y: auto; padding-right: 5px;">
                                        <div class="text-center py-5" id="historyLoading-@app.Id">
                                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                            <p class="text-muted small mt-2">Loading clinical history...</p>
                                        </div>
                                        <div id="historyContent-@app.Id" style="display: none;">
                                            <!-- Dynamic AJAX load -->
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer border-0 p-4 bg-light" style="border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
                            <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-gradient rounded-pill px-4">Save Notes & Confirm</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}

<!-- Glassmorphic Zoom Modal -->
<div class="modal fade" id="reportZoomModal" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0" style="background: rgba(30, 30, 30, 0.85); backdrop-filter: blur(10px); border-radius: 16px;">
            <div class="modal-header border-0 text-white p-4">
                <h5 class="modal-title font-heading fw-bold">Clinical Report Viewer</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <img id="zoomedReportImg" src="" class="img-fluid rounded border shadow-lg" style="max-height: 70vh; object-fit: contain;" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Script libraries for charts and calendar -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modals = document.querySelectorAll('[id^="consultNotesModal-"]');
            modals.forEach(modal => {
                modal.addEventListener('show.bs.modal', function () {
                    const appId = this.id.split('-')[1];
                    const patientId = this.getAttribute('data-patient-id');
                    
                    const loadingDiv = document.getElementById(`historyLoading-${appId}`);
                    const contentDiv = document.getElementById(`historyContent-${appId}`);
                    
                    if (contentDiv.getAttribute('data-loaded') === 'true') return; // already loaded

                    fetch(`/Doctor/GetPatientHistory?patientId=${patientId}`)
                        .then(response => response.json())
                        .then(data => {
                            loadingDiv.style.display = 'none';
                            contentDiv.style.display = 'block';
                            contentDiv.setAttribute('data-loaded', 'true');

                            let html = '';
                            
                            // Bio
                            html += `
                                <div class="bg-light p-3 rounded mb-3 small border">
                                    <div class="row text-center g-0">
                                        <div class="col-4 border-end"><strong>DOB</strong><br><span class="text-muted">${data.dob}</span></div>
                                        <div class="col-4 border-end"><strong>Gender</strong><br><span class="text-muted">${data.gender}</span></div>
                                        <div class="col-4"><strong>Blood</strong><br><span class="text-muted">${data.bloodGroup || 'N/A'}</span></div>
                                    </div>
                                    <div class="mt-2 pt-2 border-top">
                                        <strong>Base History Summary:</strong><br>
                                        <span class="text-secondary">${data.medicalHistory || 'No baseline history recorded.'}</span>
                                    </div>
                                </div>
                            `;

                            // Past Consultations Timeline
                            if (data.history.length === 0) {
                                html += `<div class="text-center py-4 text-muted small"><i class="bi bi-journal-x d-block fs-3 mb-1"></i>No past clinical entries found.</div>`;
                            } else {
                                html += '<div class="timeline-feed">';
                                data.history.forEach(item => {
                                    html += `
                                        <div class="border p-2.5 rounded bg-white mb-2 shadow-xs">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="fw-bold text-primary small">${item.date}</span>
                                                <span class="badge bg-light text-dark border small" style="font-size: 0.7rem;">Dr. ${item.doctorName}</span>
                                            </div>
                                            <div class="small mb-1"><strong>Symptoms:</strong> <span class="text-secondary">${item.symptoms}</span></div>
                                            <div class="small p-2 bg-light rounded border mb-1" style="white-space: pre-line;"><strong>Advice:</strong> ${item.notes}</div>
                                    `;
                                    
                                    // Render attachment inline
                                    if (item.prescriptionPath) {
                                        if (item.prescriptionPath.toLowerCase().endsWith('.pdf')) {
                                            html += `
                                                <div class="mt-2">
                                                    <a href="${item.prescriptionPath}" target="_blank" class="btn btn-outline-danger btn-xs py-1 px-2 text-decoration-none small" style="font-size: 0.75rem;">
                                                        <i class="bi bi-file-pdf me-1"></i>View Clinical PDF Report
                                                    </a>
                                                </div>
                                            `;
                                        } else {
                                            html += `
                                                <div class="mt-2 text-center bg-light p-2 rounded">
                                                    <div class="small text-secondary fw-semibold mb-1" style="font-size: 0.7rem;">Patient Uploaded Prescription Scan:</div>
                                                    <img src="${item.prescriptionPath}" class="img-thumbnail img-fluid rounded" style="max-height: 120px; cursor: zoom-in; object-fit: contain;" onclick="zoomDoctorReport('${item.prescriptionPath}')" />
                                                </div>
                                            `;
                                        }
                                    }

                                    html += `</div>`;
                                });
                                html += '</div>';
                            }

                            contentDiv.innerHTML = html;
                        })
                        .catch(err => {
                            loadingDiv.innerHTML = `<span class="text-danger small">Failed to load medical history.</span>`;
                        });
                });
            });

            // Listen to textarea typing for suggestions
            const textareas = document.querySelectorAll('.notes-textarea');
            textareas.forEach(textarea => {
                textarea.addEventListener('input', function () {
                    const appId = this.getAttribute('data-app-id');
                    const text = this.value.toLowerCase();
                    const suggestionsDiv = document.getElementById(`suggestions-${appId}`);
                    
                    suggestionsDiv.innerHTML = '<span class="text-secondary me-1"><i class="bi bi-lightbulb-fill text-warning"></i> Suggestions:</span>';
                    
                    const matches = [];

                    const suggestionDatabase = [
                        { 
                            category: 'Heart',
                            keywords: ['heart', 'cardio', 'chest', 'bp', 'hypertension'],
                            medicines: [
                                { name: 'Aspirin 75mg OD', text: 'Aspirin (75mg) - 1 tab daily after food.' },
                                { name: 'Atorvastatin 20mg HS', text: 'Atorvastatin (20mg) - 1 tab daily at night.' },
                                { name: 'Metoprolol 25mg BD', text: 'Metoprolol (25mg) - 1 tab twice daily.' }
                            ],
                            advice: 'Advice: Monitor blood pressure daily, restrict sodium intake.'
                        },
                        {
                            category: 'Fever',
                            keywords: ['fever', 'temp', 'body pain', 'headache'],
                            medicines: [
                                { name: 'Paracetamol 500mg TDS', text: 'Paracetamol (500mg) - 1 tab thrice daily.' },
                                { name: 'Ibuprofen 400mg SOS', text: 'Ibuprofen (400mg) - 1 tab as needed for severe pain/fever.' }
                            ],
                            advice: 'Advice: Tepid sponging, bed rest, increase oral fluid intake.'
                        },
                        {
                            category: 'Stomach',
                            keywords: ['stomach', 'gastric', 'pain', 'acid', 'diarrhea'],
                            medicines: [
                                { name: 'Omeprazole 20mg BD', text: 'Omeprazole (20mg) - 1 cap twice daily before meals.' },
                                { name: 'Gaviscon Syrup 10ml TDS', text: 'Gaviscon Syrup - 10ml thrice daily after meals.' }
                            ],
                            advice: 'Advice: Avoid spicy/fatty food, take small frequent meals.'
                        },
                        {
                            category: 'Cough/Cold',
                            keywords: ['cough', 'flu', 'cold', 'throat', 'coughing'],
                            medicines: [
                                { name: 'Loratadine 10mg OD', text: 'Loratadine (10mg) - 1 tab daily at night.' },
                                { name: 'Cough Syrup 5ml TDS', text: 'Cough Syrup - 5ml thrice daily.' }
                            ],
                            advice: 'Advice: Warm saline gargles, steam inhalation twice daily.'
                        },
                        {
                            category: 'Diabetes',
                            keywords: ['sugar', 'diabetes', 'diabetic', 'glucose'],
                            medicines: [
                                { name: 'Metformin 500mg BD', text: 'Metformin (500mg) - 1 tab twice daily with meals.' },
                                { name: 'Glimepiride 1mg OD', text: 'Glimepiride (1mg) - 1 tab daily before breakfast.' }
                            ],
                            advice: 'Advice: Restrict sugar, walk 30 mins daily, monitor blood glucose.'
                        }
                    ];

                    suggestionDatabase.forEach(item => {
                        let matched = false;
                        item.keywords.forEach(keyword => {
                            if (text.includes(keyword)) {
                                matched = true;
                            }
                        });
                        if (matched) {
                            matches.push(item);
                        }
                    });

                    if (matches.length > 0) {
                        suggestionsDiv.classList.remove('d-none');
                        matches.forEach(match => {
                            // Category label
                            const label = document.createElement('span');
                            label.className = 'badge bg-teal-100 text-teal-800 me-1 mb-1';
                            label.style.background = 'rgba(13, 148, 136, 0.1)';
                            label.style.color = 'var(--primary-color)';
                            label.innerText = match.category;
                            suggestionsDiv.appendChild(label);

                            // Med pills
                            match.medicines.forEach(med => {
                                const pill = document.createElement('button');
                                pill.type = 'button';
                                pill.className = 'btn btn-outline-info btn-xs py-0.5 px-2 rounded-pill small me-1 mb-1';
                                pill.style.fontSize = '0.75rem';
                                pill.innerText = '+ ' + med.name;
                                pill.onclick = function() {
                                    const separator = textarea.value.trim() !== '' ? '\n' : '';
                                    textarea.value += separator + med.text;
                                };
                                suggestionsDiv.appendChild(pill);
                            });

                            // Advice pill
                            const advicePill = document.createElement('button');
                            advicePill.type = 'button';
                            advicePill.className = 'btn btn-outline-secondary btn-xs py-0.5 px-2 rounded-pill small me-1 mb-1';
                            advicePill.style.fontSize = '0.75rem';
                            advicePill.innerText = '+ ' + match.advice.split(':')[0];
                            advicePill.onclick = function() {
                                const separator = textarea.value.trim() !== '' ? '\n' : '';
                                textarea.value += separator + match.advice;
                            };
                            suggestionsDiv.appendChild(advicePill);
                        });
                    } else {
                        suggestionsDiv.classList.add('d-none');
                    }
                });
            });
        });

        function zoomDoctorReport(path) {
            document.getElementById('zoomedReportImg').src = path;
            const modal = new bootstrap.Modal(document.getElementById('reportZoomModal'));
            modal.show();
        }

        let doctorTrendChartInstance = null;
        let doctorStatusChartInstance = null;

        function loadDoctorAnalytics() {
            fetch('/Doctor/GetDashboardStats')
                .then(response => response.json())
                .then(data => {
                    const trendLabels = data.weeklyTrend.map(t => t.date);
                    const trendValues = data.weeklyTrend.map(t => t.count);

                    if (doctorTrendChartInstance) doctorTrendChartInstance.destroy();
                    if (doctorStatusChartInstance) doctorStatusChartInstance.destroy();

                    const ctxTrend = document.getElementById('doctorTrendChart').getContext('2d');
                    doctorTrendChartInstance = new Chart(ctxTrend, {
                        type: 'line',
                        data: {
                            labels: trendLabels,
                            datasets: [{
                                label: 'Patients Consulted',
                                data: trendValues,
                                borderColor: 'rgba(6, 182, 212, 1)',
                                backgroundColor: 'rgba(6, 182, 212, 0.15)',
                                borderWidth: 3,
                                fill: true,
                                tension: 0.4,
                                pointBackgroundColor: 'rgba(6, 182, 212, 1)'
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: false } },
                            scales: {
                                y: { beginAtZero: true, ticks: { stepSize: 1 } }
                            }
                        }
                    });

                    const ctxStatus = document.getElementById('doctorStatusChart').getContext('2d');
                    doctorStatusChartInstance = new Chart(ctxStatus, {
                        type: 'doughnut',
                        data: {
                            labels: ['Pending', 'Approved', 'Conducted', 'Rejected'],
                            datasets: [{
                                data: [data.stats.pending, data.stats.approved, data.stats.conducted, data.stats.rejected],
                                backgroundColor: [
                                    'rgba(245, 158, 11, 0.75)',
                                    'rgba(59, 130, 246, 0.75)',
                                    'rgba(16, 185, 129, 0.75)',
                                    'rgba(239, 68, 68, 0.75)'
                                ],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { position: 'bottom', labels: { boxWidth: 10, padding: 10 } }
                            },
                            cutout: '60%'
                        }
                    });
                })
                .catch(err => console.error('Error fetching doctor stats:', err));
        }

        let doctorCalendarInstance = null;

        function loadDoctorCalendar() {
            setTimeout(() => {
                const calendarEl = document.getElementById('doctorCalendar');
                if (doctorCalendarInstance) {
                    doctorCalendarInstance.refetchEvents();
                    doctorCalendarInstance.render();
                    return;
                }

                doctorCalendarInstance = new FullCalendar.Calendar(calendarEl, {
                    initialView: 'dayGridMonth',
                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: 'dayGridMonth,timeGridWeek,timeGridDay'
                    },
                    events: '/Doctor/GetAppointmentsJson',
                    eventClick: function(info) {
                        const appId = info.event.id;
                        const modalEl = document.getElementById(`consultNotesModal-${appId}`);
                        if (modalEl) {
                            const modal = new bootstrap.Modal(modalEl);
                            modal.show();
                        } else {
                            alert("Appointment Details: " + info.event.title + " at " + info.event.start.toLocaleString());
                        }
                    }
                });
                doctorCalendarInstance.render();
            }, 200);
        }
    </script>
}
