@{
    ViewData["Title"] = "Doctor Dashboard";
    var todayAppointments = ViewBag.TodayAppointments as List<HospitalManagementPortal.Models.Appointment>;
    var upcomingAppointments = ViewBag.UpcomingAppointments as List<HospitalManagementPortal.Models.Appointment>;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="font-heading fw-bold mb-1">Welcome, Dr. @ViewBag.DoctorName</h2>
            <p class="text-secondary mb-0">Overview of your consultations, patients, and schedule today.</p>
        </div>
        <div>
            <a asp-action="Availability" class="btn btn-gradient-secondary rounded-pill px-4">
                <i class="bi bi-clock me-2"></i>Manage Hours
            </a>
        </div>
    </div>

    <!-- Stats row -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="stat-card bg-gradient-primary">
                <div class="stat-icon"><i class="bi bi-calendar2-check"></i></div>
                <div class="stat-num">@ViewBag.TodayAppointmentsCount</div>
                <div class="stat-label">Appointments Today</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card bg-gradient-accent">
                <div class="stat-icon"><i class="bi bi-calendar-event"></i></div>
                <div class="stat-num">@ViewBag.UpcomingAppointmentsCount</div>
                <div class="stat-label">Upcoming Agenda</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card bg-gradient-primary" style="filter: hue-rotate(90deg);">
                <div class="stat-icon"><i class="bi bi-journal-check"></i></div>
                <div class="stat-num">@ViewBag.ConsultationsCompleted</div>
                <div class="stat-label">Consultations Done</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Today's Appointments -->
        <div class="col-lg-7">
            <div class="card glass-card border-0 p-4 shadow-sm h-100">
                <h5 class="font-heading fw-bold mb-3"><i class="bi bi-play-circle text-primary me-2"></i>Today's Appointments Queue</h5>
                
                @if (todayAppointments == null || !todayAppointments.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-minus fs-1 text-muted"></i>
                        <p class="text-secondary small mt-2">No appointments scheduled for today.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table custom-table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Patient Details</th>
                                    <th>Time</th>
                                    <th>Symptoms</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in todayAppointments)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@app.Patient.User.FullName</div>
                                            <div class="text-muted small">DOB: @app.Patient.DateOfBirth.ToString("dd MMM yyyy") (@app.Patient.Gender)</div>
                                        </td>
                                        <td class="fw-medium text-secondary">
                                            @app.AppointmentDate.ToString("hh:mm tt")
                                        </td>
                                        <td class="small text-muted">@app.SymptomDescription</td>
                                        <td class="text-end">
                                            <button type="button" class="btn btn-gradient btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#consultNotesModal-@app.Id">
                                                Consult
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Upcoming Appointments -->
        <div class="col-lg-5">
            <div class="card glass-card border-0 p-4 shadow-sm h-100">
                <h5 class="font-heading fw-bold mb-3"><i class="bi bi-calendar-event text-secondary me-2"></i>Upcoming Agenda</h5>
                
                @if (upcomingAppointments == null || !upcomingAppointments.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-x fs-1 text-muted"></i>
                        <p class="text-secondary small mt-2">No upcoming appointments scheduled.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var app in upcomingAppointments)
                        {
                            <div class="list-group-item bg-transparent px-0 py-3 border-bottom">
                                <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                                    <h6 class="mb-0 fw-semibold">@app.Patient.User.FullName</h6>
                                    <small class="badge bg-teal-100 text-teal-800" style="background: rgba(13, 148, 136, 0.1); color: var(--primary-color);">@app.AppointmentDate.ToString("dd MMM, hh:mm tt")</small>
                                </div>
                                <p class="mb-0 text-muted small text-truncate">@app.SymptomDescription</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (todayAppointments != null && todayAppointments.Any())
{
    @foreach (var app in todayAppointments)
    {
        <!-- Notes Modal -->
        <div class="modal fade" id="consultNotesModal-@app.Id" tabindex="-1" data-patient-id="@app.PatientId" aria-labelledby="modalLabel-@app.Id" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
                    <div class="modal-header border-0 bg-light p-4" style="border-top-left-radius: 16px; border-top-right-radius: 16px;">
                        <h5 class="modal-title font-heading fw-bold" id="modalLabel-@app.Id">Patient Consultation</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form asp-action="AddConsultationNotes" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="appointmentId" value="@app.Id" />
                        <div class="modal-body p-4 text-start">
                            <div class="row g-4">
                                <!-- Left Column: Form -->
                                <div class="col-md-6 border-end">
                                    <div class="mb-3">
                                        <div class="small text-secondary fw-semibold">PATIENT</div>
                                        <div class="fw-bold fs-5 text-primary">@app.Patient.User.FullName</div>
                                    </div>
                                    <div class="mb-3 bg-light p-3 rounded-3 border">
                                        <div class="small text-secondary fw-semibold">SYMPTOMS REPORTED</div>
                                        <div class="small text-dark mt-1">@app.SymptomDescription</div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small text-secondary fw-semibold">CONSULTATION NOTES & DIAGNOSIS</label>
                                        <textarea name="notes" rows="6" class="form-control form-control-custom" placeholder="Write diagnosed symptoms, advice, and prescriptions here..." required>@app.ConsultationNotes</textarea>
                                    </div>
                                </div>

                                <!-- Right Column: Medical History -->
                                <div class="col-md-6">
                                    <h6 class="font-heading fw-bold mb-3 text-secondary"><i class="bi bi-clock-history me-2"></i>Medical History & Reports</h6>
                                    <div id="historyFeed-@app.Id" style="max-height: 350px; overflow-y: auto; padding-right: 5px;">
                                        <div class="text-center py-5" id="historyLoading-@app.Id">
                                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                            <p class="text-muted small mt-2">Loading clinical history...</p>
                                        </div>
                                        <div id="historyContent-@app.Id" style="display: none;">
                                            <!-- Dynamic AJAX load -->
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer border-0 p-4 bg-light" style="border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
                            <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-gradient rounded-pill px-4">Save Notes & Confirm</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}

<!-- Glassmorphic Zoom Modal -->
<div class="modal fade" id="reportZoomModal" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0" style="background: rgba(30, 30, 30, 0.85); backdrop-filter: blur(10px); border-radius: 16px;">
            <div class="modal-header border-0 text-white p-4">
                <h5 class="modal-title font-heading fw-bold">Clinical Report Viewer</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <img id="zoomedReportImg" src="" class="img-fluid rounded border shadow-lg" style="max-height: 70vh; object-fit: contain;" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modals = document.querySelectorAll('[id^="consultNotesModal-"]');
            modals.forEach(modal => {
                modal.addEventListener('show.bs.modal', function () {
                    const appId = this.id.split('-')[1];
                    const patientId = this.getAttribute('data-patient-id');
                    
                    const loadingDiv = document.getElementById(`historyLoading-${appId}`);
                    const contentDiv = document.getElementById(`historyContent-${appId}`);
                    
                    if (contentDiv.getAttribute('data-loaded') === 'true') return; // already loaded

                    fetch(`/Doctor/GetPatientHistory?patientId=${patientId}`)
                        .then(response => response.json())
                        .then(data => {
                            loadingDiv.style.display = 'none';
                            contentDiv.style.display = 'block';
                            contentDiv.setAttribute('data-loaded', 'true');

                            let html = '';
                            
                            // Bio
                            html += `
                                <div class="bg-light p-3 rounded mb-3 small border">
                                    <div class="row text-center g-0">
                                        <div class="col-4 border-end"><strong>DOB</strong><br><span class="text-muted">${data.dob}</span></div>
                                        <div class="col-4 border-end"><strong>Gender</strong><br><span class="text-muted">${data.gender}</span></div>
                                        <div class="col-4"><strong>Blood</strong><br><span class="text-muted">${data.bloodGroup || 'N/A'}</span></div>
                                    </div>
                                    <div class="mt-2 pt-2 border-top">
                                        <strong>Base History Summary:</strong><br>
                                        <span class="text-secondary">${data.medicalHistory || 'No baseline history recorded.'}</span>
                                    </div>
                                </div>
                            `;

                            // Past Consultations Timeline
                            if (data.history.length === 0) {
                                html += `<div class="text-center py-4 text-muted small"><i class="bi bi-journal-x d-block fs-3 mb-1"></i>No past clinical entries found.</div>`;
                            } else {
                                html += '<div class="timeline-feed">';
                                data.history.forEach(item => {
                                    html += `
                                        <div class="border p-2.5 rounded bg-white mb-2 shadow-xs">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="fw-bold text-primary small">${item.date}</span>
                                                <span class="badge bg-light text-dark border small" style="font-size: 0.7rem;">Dr. ${item.doctorName}</span>
                                            </div>
                                            <div class="small mb-1"><strong>Symptoms:</strong> <span class="text-secondary">${item.symptoms}</span></div>
                                            <div class="small p-2 bg-light rounded border mb-1" style="white-space: pre-line;"><strong>Advice:</strong> ${item.notes}</div>
                                    `;
                                    
                                    // Render attachment inline
                                    if (item.prescriptionPath) {
                                        if (item.prescriptionPath.toLowerCase().endsWith('.pdf')) {
                                            html += `
                                                <div class="mt-2">
                                                    <a href="${item.prescriptionPath}" target="_blank" class="btn btn-outline-danger btn-xs py-1 px-2 text-decoration-none small" style="font-size: 0.75rem;">
                                                        <i class="bi bi-file-pdf me-1"></i>View Clinical PDF Report
                                                    </a>
                                                </div>
                                            `;
                                        } else {
                                            html += `
                                                <div class="mt-2 text-center bg-light p-2 rounded">
                                                    <div class="small text-secondary fw-semibold mb-1" style="font-size: 0.7rem;">Patient Uploaded Prescription Scan:</div>
                                                    <img src="${item.prescriptionPath}" class="img-thumbnail img-fluid rounded" style="max-height: 120px; cursor: zoom-in; object-fit: contain;" onclick="zoomDoctorReport('${item.prescriptionPath}')" />
                                                </div>
                                            `;
                                        }
                                    }

                                    html += `</div>`;
                                });
                                html += '</div>';
                            }

                            contentDiv.innerHTML = html;
                        })
                        .catch(err => {
                            loadingDiv.innerHTML = `<span class="text-danger small">Failed to load medical history.</span>`;
                            console.error(err);
                        });
                });
            });
        });

        function zoomDoctorReport(path) {
            document.getElementById('zoomedReportImg').src = path;
            const modal = new bootstrap.Modal(document.getElementById('reportZoomModal'));
            modal.show();
        }
    </script>
}
