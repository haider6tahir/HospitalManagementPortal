@model IEnumerable<HospitalManagementPortal.Models.Appointment>
@{
    ViewData["Title"] = "Consultation Logs";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="font-heading fw-bold mb-1">Consultation & Diagnostic Logs</h2>
            <p class="text-secondary mb-0">Review clinical diagnoses, notes, and histories of treated patients.</p>
        </div>
    </div>

    <div class="card glass-card border-0 p-4 shadow-sm">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-journal-medical fs-1 text-muted"></i>
                <p class="text-secondary small mt-2">No past consultations recorded.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table custom-table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Patient Name</th>
                            <th>Date Conducted</th>
                            <th>Symptom Summary</th>
                            <th>Clinical Notes & Advice</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var consultation in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold text-primary">@consultation.Patient.User.FullName</div>
                                    <div class="text-muted small">DOB: @consultation.Patient.DateOfBirth.ToString("dd MMM yyyy") (@consultation.Patient.Gender)</div>
                                </td>
                                <td>
                                    <div class="fw-medium text-secondary">@consultation.AppointmentDate.ToString("dd MMM yyyy")</div>
                                    <div class="text-muted small">@consultation.AppointmentDate.ToString("hh:mm tt")</div>
                                </td>
                                <td>
                                    <div class="small text-muted" style="max-width: 200px;">@consultation.SymptomDescription</div>
                                </td>
                                <td>
                                    <div class="bg-light p-3 rounded border small text-dark" style="max-width: 400px; white-space: pre-line;">@consultation.ConsultationNotes</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
