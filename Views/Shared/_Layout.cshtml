<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hospital Care Portal</title>
    
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Custom Design CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HospitalManagementPortal.styles.css" asp-append-version="true" />
    <script>
        (function () {
            var offset = new Date().getTimezoneOffset();
            document.cookie = "timezoneoffset=" + offset + "; path=/; max-age=31536000; SameSite=Lax";
        })();
    </script>
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
        <div class="dashboard-layout">
            <!-- Sidebar Panel -->
            <aside class="sidebar">
                <div class="d-flex align-items-center gap-2 mb-4 px-2">
                    <span class="fs-4 text-primary" style="color: var(--primary-light) !important;"><i class="bi bi-heart-pulse-fill"></i></span>
                    <span class="fs-5 fw-bold text-white font-heading">Hospital Portal</span>
                </div>
                
                <div class="text-secondary small px-2 mb-2 text-uppercase tracking-wider">Navigation</div>
                
                <nav class="nav flex-column flex-grow-1">
                    @if (role == "Admin")
                    {
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Admin" asp-action="Dashboard">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Doctors" ? "active" : "")" asp-controller="Admin" asp-action="Doctors">
                            <i class="bi bi-file-medical"></i> Manage Doctors
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Patients" ? "active" : "")" asp-controller="Admin" asp-action="Patients">
                            <i class="bi bi-people"></i> Manage Patients
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Appointments" ? "active" : "")" asp-controller="Admin" asp-action="Appointments">
                            <i class="bi bi-calendar3"></i> Appointments
                        </a>
                    }
                    else if (role == "Doctor")
                    {
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Doctor" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Doctor" asp-action="Dashboard">
                            <i class="bi bi-speedometer2"></i> My Dashboard
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Doctor" && ViewContext.RouteData.Values["action"]?.ToString() == "Availability" ? "active" : "")" asp-controller="Doctor" asp-action="Availability">
                            <i class="bi bi-clock"></i> Set Availability
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Doctor" && ViewContext.RouteData.Values["action"]?.ToString() == "Consultations" ? "active" : "")" asp-controller="Doctor" asp-action="Consultations">
                            <i class="bi bi-journal-medical"></i> Consultations
                        </a>
                    }
                    else if (role == "Patient")
                    {
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Patient" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Patient" asp-action="Dashboard">
                            <i class="bi bi-speedometer2"></i> My Dashboard
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Patient" && ViewContext.RouteData.Values["action"]?.ToString() == "BookAppointment" ? "active" : "")" asp-controller="Patient" asp-action="BookAppointment">
                            <i class="bi bi-calendar-plus"></i> Book Appointment
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Patient" && ViewContext.RouteData.Values["action"]?.ToString() == "Notifications" ? "active" : "")" asp-controller="Patient" asp-action="Notifications">
                            <i class="bi bi-bell"></i> Notifications
                        </a>
                    }
                </nav>
                
                <div class="mt-auto pt-3 border-top border-slate-700 border-opacity-25">
                    <div class="text-white-50 small mb-2 px-2 d-flex align-items-center gap-2">
                        <i class="bi bi-person-circle fs-6 text-primary"></i>
                        <span class="text-truncate" title="@User.Identity.Name">@User.Identity.Name</span>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100 rounded-10 py-2">
                            <i class="bi bi-box-arrow-left me-1"></i> Sign Out
                        </button>
                    </form>
                </div>
            </aside>

            <!-- Main Work Content -->
            <main class="main-content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <!-- Public layout wrapper -->
        <header>
            <nav class="navbar navbar-expand-lg navbar-custom shadow-sm py-3">
                <div class="container">
                    <a class="navbar-brand d-flex align-items-center gap-2 text-gradient" asp-controller="Home" asp-action="Index">
                        <span class="fs-4"><i class="bi bi-heart-pulse-fill"></i></span>
                        <span class="fw-bold font-heading">Hospital Care</span>
                    </a>
                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#publicNavbar" aria-controls="publicNavbar" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="publicNavbar">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                            <li class="nav-item">
                                <a class="nav-link fw-semibold text-secondary" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-semibold text-secondary" href="/#services">Services</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-semibold text-secondary" href="/#about">About Us</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-semibold text-secondary" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                            </li>
                        </ul>
                        <div class="d-flex gap-2 align-items-center">
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-custom">Sign In</a>
                            <div class="dropdown">
                                <button class="btn btn-gradient dropdown-toggle" type="button" id="registerDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    Register
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm rounded-3 mt-2" aria-labelledby="registerDropdown">
                                    <li>
                                        <a class="dropdown-item py-2 px-3 fw-medium small" asp-controller="Account" asp-action="RegisterPatient">
                                            <i class="bi bi-person me-2 text-primary"></i>Register as Patient
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2 px-3 fw-medium small" asp-controller="Account" asp-action="RegisterDoctor">
                                            <i class="bi bi-file-earmark-medical me-2 text-teal-600"></i>Apply as Doctor
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main role="main">
            @RenderBody()
        </main>

        <footer class="bg-white border-top py-4 mt-auto">
            <div class="container text-center">
                <p class="text-muted small mb-0">&copy; 2026 Hospital Care System. All rights reserved. <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-muted fw-semibold">Privacy Policy</a></p>
            </div>
        </footer>
    }

    <!-- jQuery, Bootstrap & Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Floating FAQ Chatbot Widget -->
    <div class="chatbot-bubble" id="chatbotBubble" onclick="toggleChatbot()">
        <i class="bi bi-chat-dots-fill" id="chatbotIcon"></i>
    </div>

    <div class="chatbot-window" id="chatbotWindow">
        <div class="chatbot-header">
            <div>
                <div class="title">Care Assistant</div>
                <div class="status"><span class="status-dot"></span> Online</div>
            </div>
            <button type="button" class="btn-close btn-close-white" onclick="toggleChatbot()"></button>
        </div>
        <div class="chatbot-messages" id="chatbotMessages">
            <div class="chat-msg bot">
                Hello! I am your Care Portal Assistant. How can I help you today?
            </div>
        </div>
        <div class="chat-quick-replies" id="chatbotQuickReplies">
            <button type="button" class="quick-reply-btn" onclick="handleQuickReply('booking')">📅 Booking Help</button>
            <button type="button" class="quick-reply-btn" onclick="handleQuickReply('specialties')">🩺 Specialties</button>
            <button type="button" class="quick-reply-btn" onclick="handleQuickReply('timings')">⏰ Timings</button>
            <button type="button" class="quick-reply-btn" onclick="handleQuickReply('emergency')">📞 Emergency</button>
        </div>
        <form id="chatbotInputForm" onsubmit="handleChatSubmit(event)" class="chatbot-input-area">
            <input type="text" id="chatbotInput" placeholder="Ask a question..." autocomplete="off" required />
            <button type="submit" class="chatbot-send-btn">
                <i class="bi bi-send-fill"></i>
            </button>
        </form>
    </div>

    <script>
        function toggleChatbot() {
            var windowEl = document.getElementById('chatbotWindow');
            var iconEl = document.getElementById('chatbotIcon');
            var bubbleEl = document.getElementById('chatbotBubble');
            
            if (windowEl.classList.contains('show')) {
                windowEl.classList.remove('show');
                bubbleEl.classList.remove('active');
                iconEl.className = "bi bi-chat-dots-fill";
            } else {
                windowEl.classList.add('show');
                bubbleEl.classList.add('active');
                iconEl.className = "bi bi-x-lg";
            }
        }

        function appendMessage(text, sender) {
            var msgContainer = document.getElementById('chatbotMessages');
            var msgDiv = document.createElement('div');
            msgDiv.className = 'chat-msg ' + sender;
            msgDiv.innerText = text;
            msgContainer.appendChild(msgDiv);
            msgContainer.scrollTop = msgContainer.scrollHeight;
        }

        function showTypingIndicator() {
            var msgContainer = document.getElementById('chatbotMessages');
            var indicator = document.createElement('div');
            indicator.className = 'typing-indicator';
            indicator.id = 'chatbotTypingIndicator';
            indicator.innerHTML = '<span></span><span></span><span></span>';
            msgContainer.appendChild(indicator);
            msgContainer.scrollTop = msgContainer.scrollHeight;
        }

        function removeTypingIndicator() {
            var indicator = document.getElementById('chatbotTypingIndicator');
            if (indicator) {
                indicator.remove();
            }
        }

        function simulateReply(replyText) {
            showTypingIndicator();
            setTimeout(function() {
                removeTypingIndicator();
                appendMessage(replyText, 'bot');
            }, 600 + Math.random() * 600);
        }

        function handleQuickReply(type) {
            var question = "";
            var answer = "";

            if (type === 'booking') {
                question = "How do I book an appointment?";
                answer = "To book an appointment:\n1. Register or Sign In to your patient account.\n2. Click 'Book Appointment' on the sidebar.\n3. Search and select a specialist.\n4. Select a date & time (the system will check and auto-approve if it matches the doctor's weekly active hours!).";
            } else if (type === 'specialties') {
                question = "What medical specialties are available?";
                answer = "We have active registered medical specialists in:\n- Cardiology\n- Dermatology\n- Neurology\n- Pediatrics\n- General Medicine\n- Orthopedics\n- Oncology\n- Gynaecology";
            } else if (type === 'timings') {
                question = "What are the clinic operational hours?";
                answer = "Our Emergency Wing is open 24/7.\nGeneral doctor consultation timings are subject to individual doctor schedules, which can be viewed via the 'Hours List' button on the Book Appointment screen.";
            } else if (type === 'emergency') {
                question = "Emergency Helpline";
                answer = "For immediate clinical emergencies, please dial our 24/7 Helpline: +1 (800) 555-0199, or proceed directly to the Emergency Room.";
            }

            appendMessage(question, 'user');
            simulateReply(answer);
        }

        function handleChatSubmit(event) {
            event.preventDefault();
            var inputEl = document.getElementById('chatbotInput');
            var text = inputEl.value.trim();
            if (!text) return;

            appendMessage(text, 'user');
            inputEl.value = '';

            var lowerText = text.toLowerCase();
            var reply = "";

            if (lowerText.includes('book') || lowerText.includes('appointment') || lowerText.includes('schedule')) {
                reply = "To schedule a consultation, log in as a Patient and head to the 'Book Appointment' tab. Choose your doctor and pick an available time slot.";
            } else if (lowerText.includes('doctor') || lowerText.includes('specialist') || lowerText.includes('timings') || lowerText.includes('hours')) {
                reply = "You can view each doctor's credentials and operational shift times directly on the 'Book Appointment' page by clicking 'Hours List'.";
            } else if (lowerText.includes('contact') || lowerText.includes('phone') || lowerText.includes('number') || lowerText.includes('call')) {
                reply = "You can contact our support line at +1 (800) 555-0100 or email us at support@hospitalcare.com.";
            } else if (lowerText.includes('emergency') || lowerText.includes('accident') || lowerText.includes('helpline')) {
                reply = "For urgent medical issues, please call our 24/7 Helpline at +1 (800) 555-0199 or go directly to the emergency wing.";
            } else if (lowerText.includes('hello') || lowerText.includes('hi') || lowerText.includes('hey')) {
                reply = "Hello! How can I assist you with the portal today? Feel free to use the quick buttons above for common topics!";
            } else {
                reply = "I'm not sure about that. Please sign in to your dashboard to submit an official request, or select one of the quick options above.";
            }

            simulateReply(reply);
        }
    </script>
</body>
</html>
