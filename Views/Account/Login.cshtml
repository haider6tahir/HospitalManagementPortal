@model HospitalManagementPortal.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="auth-wrapper py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["PendingApprovalMessage"] != null)
                {
                    <div class="alert alert-info alert-dismissible fade show border-0 shadow-sm mb-4 rounded-3" role="alert">
                        <div class="d-flex">
                            <div class="me-2"><i class="bi bi-clock-history fs-5"></i></div>
                            <div>
                                @TempData["PendingApprovalMessage"]
                            </div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="card glass-card p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-gradient-primary text-white rounded-circle mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-heart-pulse-fill fs-3"></i>
                        </div>
                        <h2 class="text-gradient font-heading mb-1">Welcome Back</h2>
                        <p class="text-muted">Sign in to access your portal dashboard</p>
                    </div>

                    <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label text-secondary fw-medium small"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 border-1.5"><i class="bi bi-envelope text-muted"></i></span>
                                <input asp-for="Email" class="form-control form-control-custom border-start-0" placeholder="name@example.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label asp-for="Password" class="form-label text-secondary fw-medium small mb-0"></label>
                            </div>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 border-1.5"><i class="bi bi-lock text-muted"></i></span>
                                <input asp-for="Password" class="form-control form-control-custom border-start-0" placeholder="••••••••" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label text-secondary small"></label>
                        </div>

                        <button type="submit" class="btn btn-gradient w-100 py-3 mb-3">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                        </button>
                    </form>

                    <div class="text-center mt-3 border-top pt-4">
                        <p class="text-secondary small mb-2">Don't have an account?</p>
                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="RegisterPatient" class="text-decoration-none small fw-semibold text-gradient">Register as Patient</a>
                            <span class="text-muted small">|</span>
                            <a asp-action="RegisterDoctor" class="text-decoration-none small fw-semibold text-gradient-accent">Apply as Doctor</a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
