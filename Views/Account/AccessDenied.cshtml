@{
    ViewData["Title"] = "Access Denied";
}

<div class="auth-wrapper py-5">
    <div class="container text-center">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card glass-card p-4 p-md-5">
                    <div class="text-danger mb-4">
                        <i class="bi bi-shield-slash fs-1"></i>
                    </div>
                    <h2 class="font-heading mb-2 text-danger">Access Denied</h2>
                    <p class="text-muted mb-4">You do not have the required permissions to access this page.</p>
                    
                    <div class="d-flex justify-content-center gap-3">
                        <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="bi bi-arrow-left me-2"></i>Go Back
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-gradient rounded-pill px-4">
                            <i class="bi bi-house-door me-2"></i>Go Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
