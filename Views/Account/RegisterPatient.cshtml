@model HospitalManagementPortal.Models.PatientRegisterViewModel
@{
    ViewData["Title"] = "Patient Registration";
}

<div class="auth-wrapper py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                
                <div class="card glass-card p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-gradient-primary text-white rounded-circle mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-person-plus-fill fs-3"></i>
                        </div>
                        <h2 class="text-gradient font-heading mb-1">Create Patient Account</h2>
                        <p class="text-muted">Register today to search doctors and book appointments online</p>
                    </div>

                    <form asp-action="RegisterPatient" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FullName" class="form-label text-secondary fw-medium small"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 border-1.5"><i class="bi bi-person text-muted"></i></span>
                                    <input asp-for="FullName" class="form-control form-control-custom border-start-0" placeholder="John Doe" />
                                </div>
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label text-secondary fw-medium small"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 border-1.5"><i class="bi bi-envelope text-muted"></i></span>
                                    <input asp-for="Email" class="form-control form-control-custom border-start-0" placeholder="john@example.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Password" class="form-label text-secondary fw-medium small"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 border-1.5"><i class="bi bi-lock text-muted"></i></span>
                                    <input asp-for="Password" class="form-control form-control-custom border-start-0" placeholder="Min 6 characters" />
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="ConfirmPassword" class="form-label text-secondary fw-medium small"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 border-1.5"><i class="bi bi-lock-fill text-muted"></i></span>
                                    <input asp-for="ConfirmPassword" class="form-control form-control-custom border-start-0" placeholder="Confirm password" />
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4 text-muted opacity-25">
                        <h5 class="font-heading mb-3 text-secondary">Personal & Medical Details</h5>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="DateOfBirth" class="form-label text-secondary fw-medium small"></label>
                                <input asp-for="DateOfBirth" class="form-control form-control-custom" />
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Gender" class="form-label text-secondary fw-medium small"></label>
                                <select asp-for="Gender" class="form-select form-control-custom">
                                    <option value="">Select Gender</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="BloodGroup" class="form-label text-secondary fw-medium small"></label>
                                <select asp-for="BloodGroup" class="form-select form-control-custom">
                                    <option value="">Select Blood Group</option>
                                    <option value="A+">A+</option>
                                    <option value="A-">A-</option>
                                    <option value="B+">B+</option>
                                    <option value="B-">B-</option>
                                    <option value="AB+">AB+</option>
                                    <option value="AB-">AB-</option>
                                    <option value="O+">O+</option>
                                    <option value="O-">O-</option>
                                </select>
                                <span asp-validation-for="BloodGroup" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="MedicalHistorySummary" class="form-label text-secondary fw-medium small"></label>
                            <textarea asp-for="MedicalHistorySummary" rows="3" class="form-control form-control-custom" placeholder="Briefly describe any chronic illnesses, ongoing medications, drug allergies, or past surgeries..."></textarea>
                            <span asp-validation-for="MedicalHistorySummary" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-action="Login" class="text-decoration-none text-muted small"><i class="bi bi-arrow-left me-1"></i> Back to login</a>
                            <button type="submit" class="btn btn-gradient py-2 px-4">
                                <i class="bi bi-person-check-fill me-2"></i>Register
                            </button>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
