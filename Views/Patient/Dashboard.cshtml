@{
    ViewData["Title"] = "Patient Dashboard";
    var appointments = ViewBag.Appointments as List<HospitalManagementPortal.Models.Appointment>;
    var notifications = ViewBag.Notifications as List<HospitalManagementPortal.Models.Notification>;
    var nextApp = ViewBag.NextAppointment as HospitalManagementPortal.Models.Appointment;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="font-heading fw-bold mb-1">Welcome, @ViewBag.PatientName</h2>
            <p class="text-secondary mb-0">Track your appointment bookings, find specialists, and check clinic updates.</p>
        </div>
        <div>
            <a asp-action="BookAppointment" class="btn btn-gradient rounded-pill px-4">
                <i class="bi bi-calendar-plus me-2"></i>Book Appointment
            </a>
        </div>
    </div>

    <!-- Next Appointment Alert Box -->
    @if (nextApp != null)
    {
        <div class="card border-0 bg-gradient-primary text-white p-4 rounded-3 shadow-sm mb-4">
            <div class="row align-items-center">
                <div class="col-md-8 mb-3 mb-md-0">
                    <div class="small text-white-50 text-uppercase fw-bold tracking-wider mb-1"><i class="bi bi-clock me-1"></i> Upcoming Consultation</div>
                    <h3 class="font-heading fw-bold mb-1">Appointment with Dr. @nextApp.Doctor.User.FullName</h3>
                    <p class="mb-0 text-white-50 small">Specialty: <strong>@nextApp.Doctor.Specialization</strong> | Scheduled for <strong>@nextApp.AppointmentDate.ToString("f")</strong></p>
                </div>
                <div class="col-md-4 text-md-end">
                    <div class="badge bg-white text-teal-800 rounded-pill px-3 py-2 fw-semibold">
                        <i class="bi bi-calendar-check me-1"></i> Approved Slot
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Stats row -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="stat-card bg-gradient-accent" style="filter: grayscale(0.2) opacity(0.85);">
                <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
                <div class="stat-num">@ViewBag.PendingRequestsCount</div>
                <div class="stat-label">Pending Bookings</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card bg-gradient-primary">
                <div class="stat-icon"><i class="bi bi-calendar-check"></i></div>
                <div class="stat-num">@ViewBag.ApprovedRequestsCount</div>
                <div class="stat-label">Approved Appointments</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card bg-gradient-accent" style="filter: hue-rotate(180deg) brightness(0.85);">
                <div class="stat-icon"><i class="bi bi-calendar-x"></i></div>
                <div class="stat-num">@ViewBag.RejectedRequestsCount</div>
                <div class="stat-label">Rejected Requests</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Appointment History -->
        <div class="col-lg-8">
            <div class="card glass-card border-0 p-4 shadow-sm h-100">
                <h5 class="font-heading fw-bold mb-3"><i class="bi bi-calendar3 text-primary me-2"></i>My Appointment Logs</h5>
                
                @if (appointments == null || !appointments.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-calendar3 fs-1 text-muted"></i>
                        <p class="text-secondary small mt-2">You haven't booked any appointments yet.</p>
                        <a asp-action="BookAppointment" class="btn btn-outline-custom btn-sm mt-3">Book Your First Appointment</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table custom-table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Doctor Name</th>
                                    <th>Appointment Date</th>
                                    <th>Symptoms</th>
                                    <th>Status</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in appointments)
                                {
                                    string statusBadgeClass = app.Status switch
                                    {
                                        "Approved" => "bg-success",
                                        "Rejected" => "bg-danger",
                                        "Conducted" => "bg-info",
                                        _ => "bg-warning text-dark"
                                    };
                                    <tr>
                                        <td>
                                            <div class="fw-semibold text-primary">Dr. @app.Doctor.User.FullName</div>
                                            <div class="badge bg-teal-100 text-teal-800" style="background: rgba(13, 148, 136, 0.1); color: var(--primary-color);">@app.Doctor.Specialization</div>
                                        </td>
                                        <td class="small">
                                            <div class="fw-medium">@app.AppointmentDate.ToString("dd MMM yyyy")</div>
                                            <div class="text-muted">@app.AppointmentDate.ToString("hh:mm tt")</div>
                                        </td>
                                        <td>
                                            <div class="text-muted small text-truncate" style="max-width: 150px;" title="@app.SymptomDescription">@app.SymptomDescription</div>
                                        </td>
                                        <td>
                                            <span class="badge @statusBadgeClass rounded-pill px-3 py-1.5 small">@app.Status</span>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(app.ConsultationNotes))
                                            {
                                                <div class="d-flex flex-column gap-1">
                                                    <button type="button" class="btn btn-outline-secondary btn-sm w-100" data-bs-toggle="modal" data-bs-target="#viewNotesModal-@app.Id">
                                                        <i class="bi bi-journal-text me-1"></i>View Notes
                                                    </button>
                                                    @if (!string.IsNullOrEmpty(app.PatientPrescriptionPath))
                                                    {
                                                        <button type="button" class="btn btn-outline-success btn-sm w-100" data-bs-toggle="modal" data-bs-target="#uploadReportModal-@app.Id">
                                                            <i class="bi bi-file-earmark-check me-1"></i>Report OK
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="btn btn-gradient-secondary btn-sm w-100" data-bs-toggle="modal" data-bs-target="#uploadReportModal-@app.Id">
                                                            <i class="bi bi-upload me-1"></i>Upload Report
                                                        </button>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Not conducted yet.</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Recent Alerts -->
        <div class="col-lg-4">
            <div class="card glass-card border-0 p-4 shadow-sm h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="font-heading fw-bold mb-0"><i class="bi bi-bell text-secondary me-2"></i>Recent Alerts</h5>
                    <a asp-action="Notifications" class="text-decoration-none small fw-semibold text-gradient">View All</a>
                </div>
                
                @if (notifications == null || !notifications.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-bell-slash fs-2 text-muted"></i>
                        <p class="text-secondary small mt-2">No alerts yet.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var note in notifications)
                        {
                            <div class="list-group-item bg-transparent px-0 py-3 @(note.IsRead ? "" : "border-start border-3 border-teal-500 ps-2")">
                                <p class="mb-1 small text-dark">@note.Message</p>
                                <div class="text-muted" style="font-size: 0.75rem;">@note.CreatedAt.ToString("g")</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (appointments != null && appointments.Any(a => !string.IsNullOrEmpty(a.ConsultationNotes)))
{
    @foreach (var app in appointments.Where(a => !string.IsNullOrEmpty(a.ConsultationNotes)))
    {
        <!-- Notes View Modal -->
        <div class="modal fade" id="viewNotesModal-@app.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
                    <div class="modal-header border-0 bg-light p-4" style="border-top-left-radius: 16px; border-top-right-radius: 16px;">
                        <h5 class="modal-title font-heading fw-bold">Consultation Summary</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4 text-start">
                        <div class="mb-3">
                            <div class="small text-secondary fw-semibold">ATTENDING DOCTOR</div>
                            <div class="fw-bold">Dr. @app.Doctor.User.FullName</div>
                            <div class="text-muted small">@app.Doctor.Specialization (@app.Doctor.Qualifications)</div>
                        </div>
                        <div class="mb-3">
                            <div class="small text-secondary fw-semibold">CONSULTATION DATE</div>
                            <div class="fw-medium text-dark">@app.AppointmentDate.ToString("f")</div>
                        </div>
                        <div class="mb-3 bg-light p-3 rounded-3 border">
                            <div class="small text-secondary fw-semibold mb-1">CLINICAL ADVICE & DIAGNOSIS</div>
                            <div class="small text-dark mt-1" style="white-space: pre-line;">@app.ConsultationNotes</div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4 bg-light" style="border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
                        <button type="button" class="btn btn-outline-primary rounded-pill px-4 me-2" onclick="printPrescription('Dr. @app.Doctor.User.FullName', '@app.Doctor.Specialization', '@app.Doctor.Qualifications', '@ViewBag.PatientName', '@app.Patient.DateOfBirth.ToString("dd MMM yyyy")', '@app.Patient.Gender', '@app.AppointmentDate.ToString("dd MMM yyyy, hh:mm tt")', '@(app.ConsultationNotes?.Replace("'", "\\'").Replace("\r\n", "\\n").Replace("\n", "\\n"))')"><i class="bi bi-printer me-1"></i>Print Prescription</button>
                        <button type="button" class="btn btn-gradient rounded-pill px-4" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Upload Prescription Modal -->
        <div class="modal fade" id="uploadReportModal-@app.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
                    <div class="modal-header border-0 bg-light p-4" style="border-top-left-radius: 16px; border-top-right-radius: 16px;">
                        <h5 class="modal-title font-heading fw-bold">Upload Clinical Report / Prescription</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form asp-action="UploadPrescription" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="appointmentId" value="@app.Id" />
                        <div class="modal-body p-4 text-start">
                            @if (!string.IsNullOrEmpty(app.PatientPrescriptionPath))
                            {
                                <div class="mb-4 text-center border p-3 rounded bg-light">
                                    <div class="small text-secondary fw-semibold mb-2">CURRENTLY UPLOADED REPORT</div>
                                    @if (app.PatientPrescriptionPath.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <div class="bg-white border rounded p-2 d-flex align-items-center justify-content-center gap-2">
                                            <i class="bi bi-file-pdf-fill text-danger fs-2"></i>
                                            <a href="@app.PatientPrescriptionPath" target="_blank" class="fw-semibold text-decoration-none">View Uploaded PDF Document</a>
                                        </div>
                                    }
                                    else
                                    {
                                        <img src="@app.PatientPrescriptionPath" class="img-thumbnail img-fluid rounded" style="max-height: 200px; object-fit: contain;" />
                                    }
                                </div>
                            }
                            <div class="mb-3">
                                <label class="form-label small text-secondary fw-semibold">SELECT NEW REPORT FILE (JPG, PNG, PDF)</label>
                                <input type="file" name="prescriptionFile" class="form-control form-control-custom" accept=".jpg,.jpeg,.png,.pdf" required />
                            </div>
                        </div>
                        <div class="modal-footer border-0 p-4 bg-light" style="border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
                            <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-gradient rounded-pill px-4">Upload Document</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}

@section Scripts {
    <script>
        function printPrescription(doctorName, specialty, qualifications, patientName, dob, gender, date, notes) {
            const printWindow = window.open('', '_blank', 'width=800,height=600');
            printWindow.document.write(`
                <html>
                <head>
                    <title>Clinical Prescription Slip</title>
                    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
                    <style>
                        body { font-family: 'Arial', sans-serif; padding: 40px; color: #333; }
                        .letterhead { border-bottom: 3px double #06a3da; padding-bottom: 20px; margin-bottom: 30px; }
                        .clinic-title { font-size: 28px; font-weight: bold; color: #06a3da; letter-spacing: 1px; }
                        .meta-section { margin-bottom: 30px; background: #f8f9fa; padding: 15px; border-radius: 8px; border: 1px solid #dee2e6; }
                        .notes-section { font-size: 16px; line-height: 1.6; white-space: pre-line; background: #fff; border: 1px solid #dee2e6; padding: 20px; border-radius: 8px; }
                        .footer { border-top: 1px solid #dee2e6; margin-top: 50px; padding-top: 15px; font-size: 12px; color: #777; }
                        @@media print {
                            body { padding: 20px; }
                            .no-print { display: none; }
                        }
                    </style>
                </head>
                <body>
                    <div class="letterhead d-flex justify-content-between align-items-center">
                       <div>
                           <div class="clinic-title">HOSPITAL CARE PORTAL</div>
                           <div class="text-muted small">Modern Digital Consultation System</div>
                       </div>
                       <div class="text-end">
                           <h5 class="mb-0 fw-bold">${doctorName}</h5>
                           <div class="text-secondary small">${specialty} (${qualifications})</div>
                       </div>
                    </div>
                    
                    <div class="row meta-section">
                       <div class="col-6 mb-2"><strong>Patient Name:</strong> ${patientName}</div>
                       <div class="col-6 mb-2"><strong>Date:</strong> ${date}</div>
                       <div class="col-6"><strong>Date of Birth:</strong> ${dob}</div>
                       <div class="col-6"><strong>Gender:</strong> ${gender}</div>
                    </div>
                    
                    <h5 class="fw-bold mb-3">Rx & Consultation Advice</h5>
                    <div class="notes-section">${notes}</div>
                    
                    <div class="text-end" style="margin-top: 60px;">
                       <div style="width: 200px; display: inline-block; border-bottom: 1px solid #333;"></div>
                       <div class="small text-muted mt-1 me-4">Doctor's Authorized Signature</div>
                    </div>
                    
                    <div class="footer text-center">
                       This is a system-generated electronic prescription log registered via Hospital Care Portal.
                    </div>
                    <script>
                       window.onload = function() { window.print(); window.close(); }
                    <\/script>
                </body>
                </html>
            `);
            printWindow.document.close();
        }
    </script>
}
